import subprocess
import sys
import warnings

count = 0
commit = ''
dirty = ''

version_file_name = 'VERSION'

try :
    with open(version_file_name, 'r') as vf :
        (version, commit, *rest) = vf.readline().strip().split('\t')

    (major, minor, patch) = version.strip('v').split('.')

    count = subprocess.check_output(['git', 'rev-list', commit + '...HEAD', '--count']).decode('utf-8').strip()


    print('{}.{}.{}'.format(major, minor, int(patch) + int(count)))
except Exception as e :
    warnings.warn('failed to compute version, using default; {}'.format(str(e)))
    print('0.0.0')
